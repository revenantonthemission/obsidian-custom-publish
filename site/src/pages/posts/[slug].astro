---
import { getAllPostMeta, getPostMeta, getPostContent } from "../../lib/data";
import { renderMarkdown } from "../../lib/render";
import PostLayout from "../../layouts/PostLayout.astro";

export function getStaticPaths() {
  const posts = getAllPostMeta();
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");
const meta = getPostMeta(slug);
if (!meta) return Astro.redirect("/404");
const rawContent = getPostContent(slug);
const htmlContent = await renderMarkdown(rawContent);
---

<PostLayout meta={meta} content={htmlContent} />
