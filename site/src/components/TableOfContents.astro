---
interface Props {
  content: string;
}

interface Heading {
  depth: number;
  text: string;
  id: string;
}

const { content } = Astro.props;

// Extract headings from rendered HTML content
const headingRegex = /<h([2-4])(?:\s+id="([^"]*)")?[^>]*>(.*?)<\/h[2-4]>/gi;
const headings: Heading[] = [];
let match;
while ((match = headingRegex.exec(content)) !== null) {
  const depth = parseInt(match[1]);
  // Strip any inner HTML tags from heading text
  const text = match[3].replace(/<[^>]+>/g, "").trim();
  const id = match[2] || text
    .toLowerCase()
    .replace(/[^\w\s가-힣-]/g, "")
    .replace(/\s+/g, "-");
  headings.push({ depth, text, id });
}
---

{headings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <h3 class="toc-title">목차</h3>
    <ul class="toc-list">
      {headings.map((h) => (
        <li class={`toc-item toc-depth-${h.depth}`}>
          <a href={`#${h.id}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    font-size: 0.85rem;
  }
  .toc-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-text-muted);
    margin-bottom: 0.75rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
  }
  .toc-item {
    margin-bottom: 0.3rem;
  }
  .toc-item a {
    color: var(--c-text-muted);
    text-decoration: none;
  }
  .toc-item a:hover {
    color: var(--c-accent);
  }
  .toc-depth-3 { padding-left: 1rem; }
  .toc-depth-4 { padding-left: 2rem; }
</style>
