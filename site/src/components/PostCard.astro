---
import type { PostMeta } from "../lib/types";
import { sanitizeTag } from "../lib/data";

interface Props {
  post: PostMeta;
  summary?: string;
}

const { post, summary } = Astro.props;
---

<article class="post-card">
  <a href={`/posts/${post.slug}`} class="post-card-title">{post.title}</a>
  <div class="post-card-meta">
    {post.published && <time datetime={post.published}>{post.published}</time>}
    <span>{post.reading_time_min}분 읽기</span>
  </div>
  {summary && <p class="post-card-summary">{summary}</p>}
  <div class="post-card-tags">
    {post.tags.slice(0, 3).map((tag) => (
      <a href={`/tags/${sanitizeTag(tag)}`} class="post-tag">{tag}</a>
    ))}
  </div>
</article>

<style>
  .post-card {
    padding: 1rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .post-card:last-child {
    border-bottom: none;
  }
  .post-card-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--c-text);
  }
  .post-card-title:hover {
    color: var(--c-accent);
    text-decoration: none;
  }
  .post-card-meta {
    display: flex;
    gap: 0.75rem;
    color: var(--c-text-muted);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .post-card-summary {
    color: var(--c-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-top: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .post-tag {
    background: var(--c-code-bg);
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }
  .post-tag:hover {
    color: var(--c-accent);
    text-decoration: none;
  }
</style>
