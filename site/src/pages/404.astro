---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPostMeta } from "../lib/data";

const recentPosts = getAllPostMeta().filter((p) => !p.is_hub).slice(0, 5);
---

<BaseLayout title="페이지를 찾을 수 없습니다">
  <div class="not-found">
    <h1>404</h1>
    <p>페이지를 찾을 수 없습니다.</p>
    <div class="not-found-actions">
      <a href="/" class="not-found-link">홈으로 돌아가기</a>
      <button class="not-found-link" data-search-open>검색으로 찾기</button>
    </div>
    {recentPosts.length > 0 && (
      <div class="not-found-recent">
        <h2>최근 글</h2>
        <ul>
          {recentPosts.map((post) => (
            <li><a href={`/posts/${post.slug}`}>{post.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 1rem;
  }
  .not-found h1 {
    font-size: 4rem;
    color: var(--c-text-muted);
    margin-bottom: 0.5rem;
  }
  .not-found p {
    color: var(--c-text-muted);
    margin-bottom: 1.5rem;
  }
  .not-found-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .not-found-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    background: none;
    color: var(--c-text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .not-found-link:hover {
    background: var(--c-code-bg);
    border-color: var(--c-accent);
    color: var(--c-text);
    text-decoration: none;
  }
  .not-found-recent {
    text-align: left;
    max-width: 400px;
    margin: 0 auto;
  }
  .not-found-recent h2 {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .not-found-recent ul {
    list-style: none;
    padding: 0;
  }
  .not-found-recent li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .not-found-recent li:last-child {
    border-bottom: none;
  }
  .not-found-recent a {
    color: var(--c-text);
    text-decoration: none;
  }
  .not-found-recent a:hover {
    color: var(--c-accent);
  }
</style>
