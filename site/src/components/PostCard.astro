---
import type { PostMeta } from "../lib/types";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;
---

<article class="post-card">
  <a href={`/posts/${post.slug}`} class="post-card-title">{post.title}</a>
  <div class="post-card-meta">
    {post.published && <time>{post.published}</time>}
    <span>{post.reading_time_min}분 읽기</span>
  </div>
  <div class="post-card-tags">
    {post.tags.slice(0, 3).map((tag) => (
      <a href={`/tags/${tag}`} class="post-tag">{tag}</a>
    ))}
  </div>
</article>

<style>
  .post-card {
    padding: 1rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .post-card:last-child {
    border-bottom: none;
  }
  .post-card-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--c-text);
  }
  .post-card-title:hover {
    color: var(--c-accent);
    text-decoration: none;
  }
  .post-card-meta {
    display: flex;
    gap: 0.75rem;
    color: var(--c-text-muted);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .post-card-tags {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
</style>
