---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getAllPostMeta, getPostContent, getPreviewSummary } from "../lib/data";
import { renderMarkdown } from "../lib/render";

const slug = "passion-project";
const rawContent = getPostContent(slug);
const htmlContent = await renderMarkdown(rawContent);

// Split at "이번주에 작성된 포스트" heading, replace with dynamic recent posts
const recentHeadingRe = /<h2[^>]*>이번주에 작성된 포스트[^<]*<\/h2>[\s\S]*?(?=<h2|$)/;
const beforeAndAfter = htmlContent.split(recentHeadingRe);
const contentBefore = beforeAndAfter[0] ?? htmlContent;
const contentAfter = beforeAndAfter[1] ?? "";

const today = new Date().toISOString().slice(0, 10);
const recentPosts = getAllPostMeta()
  .filter((p) => !p.is_hub && p.published === today);
---

<BaseLayout title="Passion Project">
  <div class="home-content post-content" set:html={contentBefore} />

  <section class="recent-posts">
    <h2>오늘 발행된 글</h2>
    {recentPosts.length > 0 ? (
      recentPosts.map((post) => (
        <PostCard post={post} summary={getPreviewSummary(post.slug)} />
      ))
    ) : (
      <p class="no-posts">오늘 발행된 글이 없습니다.</p>
    )}
  </section>

  {contentAfter && <div class="home-content post-content" set:html={contentAfter} />}
</BaseLayout>

<style>
  .home-content {
    margin-bottom: 2rem;
  }
  .recent-posts {
    margin-bottom: 2rem;
  }
  .no-posts {
    color: var(--c-text-muted);
    font-size: 0.9rem;
  }
</style>
