---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import BacklinkList from "../components/BacklinkList.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import HubNav from "../components/HubNav.astro";
import LocalGraph from "../islands/LocalGraph.tsx";
import NavTreeIsland from "../islands/NavTree.tsx";
import { sanitizeTag, getLocalGraph, getPostMeta, getAllPostMeta, formatDateKo } from "../lib/data";
import type { PostMeta } from "../lib/types";
import MobileSidebar from "../islands/MobileSidebar.tsx";
import "../styles/post.css";
import "../styles/link-preview.css";
import "../styles/nav-tree.css";
import "../styles/mobile-sidebar.css";

interface Props {
  meta: PostMeta;
  content: string;
}

const { meta, content } = Astro.props;
const localGraphData = getLocalGraph(meta.slug);

// Use hub_parent field directly instead of scanning all hubs' forward_links
let parentHub: PostMeta | undefined;
let hubChildren: PostMeta[] = [];
if (meta.hub_parent) {
  const allMeta = getAllPostMeta();
  parentHub = allMeta.find((p) => p.title === meta.hub_parent);
  if (parentHub) {
    hubChildren = (parentHub.forward_links || [])
      .map((s) => getPostMeta(s))
      .filter((m): m is PostMeta => m !== null);
  }
}
---

<BaseLayout
  title={meta.title}
  description={meta.description || `${meta.title} — ${meta.tags.join(", ")}`}
  ogType="article"
  canonicalUrl={`/posts/${meta.slug}`}
>
  {parentHub && (
    <HubNav hub={parentHub} current={meta} children={hubChildren} />
  )}
  <div class="post-layout">
    <article>
      <header class="post-header">
        <h1 class="post-title">{meta.title}</h1>
        <div class="post-meta">
          {meta.published && <time datetime={meta.published}>{formatDateKo(meta.published)}</time>}
          {meta.updated && meta.updated !== meta.published && (
            <span>수정: <time datetime={meta.updated}>{formatDateKo(meta.updated)}</time></span>
          )}
          <span>{meta.reading_time_min}분 읽기</span>
          {meta.tags.map((tag) => (
            <a href={`/tags/${sanitizeTag(tag)}`} class="post-tag">{tag}</a>
          ))}
        </div>
      </header>
      {/* SECURITY: set:html trusts the vault content. rehype-raw passes through HTML from the
          preprocessor (callout divs, wikilink anchors). This is safe for a personal vault but
          must be revisited if the vault ever accepts third-party content. */}
      <div class="post-content" set:html={content} />
      <RelatedPosts slugs={meta.related_posts ?? []} />
      <BacklinkList backlinks={meta.backlinks} />
    </article>
    <aside class="post-sidebar">
      <NavTreeIsland client:visible currentSlug={meta.slug} />
      <TableOfContents content={content} />
      <LocalGraph client:visible slug={meta.slug} data={localGraphData} />
    </aside>
  </div>
<script>
  import "../scripts/copy-button";
</script>
<script>
  import "../scripts/link-preview";
</script>
<script>
  import "../scripts/toc-highlight";
</script>
<script>
  import "../scripts/diagram-wrap";
</script>
<script>
  import "../scripts/heading-fold";
</script>
<MobileSidebar client:visible content={content} currentSlug={meta.slug} />
</BaseLayout>
