---
import BaseLayout from "../layouts/BaseLayout.astro";
import GraphView from "../islands/GraphView.tsx";
import { getGraph } from "../lib/data";

const graphData = getGraph();
---

<BaseLayout title="Graph">
  <h1>그래프 뷰</h1>
  <div class="graph-container">
    <GraphView client:load data={graphData} />
  </div>
</BaseLayout>

<style>
  .graph-container {
    margin-top: 1rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;
  }
</style>
