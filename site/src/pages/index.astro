---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getAllPostMeta, getHubs } from "../lib/data";

const posts = getAllPostMeta().filter((p) => !p.is_hub).slice(0, 20);
const hubs = getHubs();
---

<BaseLayout title="Blog">
  {hubs.length > 0 && (
    <section class="hubs-section">
      <h2>허브</h2>
      <div class="hub-list">
        {hubs.map((hub) => (
          <a href={`/hubs/${hub.slug}`} class="hub-card">
            <span class="hub-title">{hub.title}</span>
            <span class="hub-tags">{hub.tags.join(", ")}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2>최근 글</h2>
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>

<style>
  .hubs-section {
    margin-bottom: 2.5rem;
  }
  .hub-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .hub-card {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    color: var(--c-text);
    text-decoration: none;
  }
  .hub-card:hover {
    border-color: var(--c-accent);
    text-decoration: none;
  }
  .hub-title {
    font-weight: 600;
  }
  .hub-tags {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    margin-top: 0.25rem;
  }
</style>
